# Database
DATABASE_URL=postgresql+asyncpg://xnews:xnews_password@localhost:5432/xnews_digest
DB_PASSWORD=xnews_password

# Redis
REDIS_URL=redis://localhost:6379/0

# Provider Configuration
X_PROVIDER=MOCK
# APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_TIMEOUT_SECONDS=300

# LLM Configuration (DeepSeek / OpenAI-compatible)
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_EMBEDDING_MODEL=deepseek-embedding
LLM_API_KEY=your_deepseek_api_key_here
LLM_MAX_TOKENS=12000

# SMTP Configuration (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@xnewsdigest.com

# Application Settings
LOG_LEVEL=INFO
APP_NAME=X-News-Digest
APP_VERSION=0.1.0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

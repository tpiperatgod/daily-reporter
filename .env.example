# Database
DATABASE_URL=postgresql+asyncpg://xnews:xnews_password@localhost:5432/xnews_digest
DB_PASSWORD=xnews_password

# Redis
REDIS_URL=redis://localhost:6379/0

# Provider Configuration
X_PROVIDER=MOCK
# APIFY_API_TOKEN=your_apify_token_here
APIFY_ACTOR_TIMEOUT_SECONDS=300
# TWITTER_API_KEY=your_twitter_api_key_here
TWITTER_API_BASE_URL=https://api.twitterapi.io
TWITTER_API_TIMEOUT_SECONDS=30
TWITTER_API_MAX_PAGES=5

# LLM Chat API Configuration (for digest generation)
LLM_CHAT_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4-turbo
LLM_CHAT_API_KEY=sk-your-chat-api-key-here

# Embedding Provider Selection
LLM_EMBEDDING_PROVIDER=openai  # "openai" or "ollama"

# OpenAI-Compatible Embedding Provider (GLM, OpenAI, etc.)
# Use these when LLM_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_EMBEDDING_MODEL=embedding-3
OPENAI_EMBEDDING_API_KEY=sk-your-embedding-api-key-here

# Ollama Embedding Provider (Local)
# Use these when LLM_EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3:567m

# Backward Compatibility (deprecated - use provider-specific variables above)
LLM_EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_EMBEDDING_MODEL=embedding-3
LLM_EMBEDDING_API_KEY=sk-your-embedding-api-key-here

# LLM Shared Configuration
LLM_MAX_TOKENS=12000

# Embedding API Rate Limiting
LLM_EMBEDDING_BATCH_SIZE=64  # Max items per batch request (GLM supports up to 64)
LLM_EMBEDDING_RETRY_MAX_ATTEMPTS=5  # Retry attempts on 429 errors
LLM_EMBEDDING_RETRY_INITIAL_BACKOFF=1.0  # Initial backoff in seconds

# SMTP Configuration (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@xnewsdigest.com

# Application Settings
LOG_LEVEL=INFO
APP_NAME=X-News-Digest
APP_VERSION=0.1.0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
